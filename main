local KEY_FILE = "LHub_Key.txt"
local SDK_URL = "https://sdkapi-public.luarmor.net/library.lua"
local WINDUI_URL = "https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"
local SCRIPT_ID = "2aa23c9675632d49560bfaca3c5f3a41"
local GET_KEY_LINK = "https://ads.luarmor.net/get_key?for=L_Hub-pOEgMKphqeOV"

local function trim(s)
    return (s or ""):match("^%s*(.-)%s*$")
end

local apiCache
local function getAPI()
    if apiCache then return apiCache end
    local ok, lib = pcall(function()
        return loadstring(game:HttpGet(SDK_URL))()
    end)
    if ok and lib then
        lib.script_id = SCRIPT_ID
        apiCache = lib
        return lib
    end
    return nil
end

local function tryLuarmor(key)
    local api = getAPI()
    if not api then
        return false, "API_LOAD_FAILED", "Could not load Luarmor API"
    end

    getgenv().script_key = key

    local ok, status = pcall(api.check_key, key)
    if not ok or type(status) ~= "table" then
        return false, "CHECK_FAILED", "check_key call failed"
    end

    if status.code == "KEY_VALID" then
        script_key = key
        pcall(api.load_script)
        return true, status.code, status.message
    end

    return false, status.code or "UNKNOWN", status.message or ""
end

local function messageForCode(code, rawMessage)
    if code == "KEY_EXPIRED" then
        return "Your key has expired. Click 'Get Key' to grab a new one."
    elseif code == "KEY_BANNED" then
        return "This key has been blacklisted. Get a new one via 'Get Key'."
    elseif code == "KEY_HWID_LOCKED" then
        return "Key linked to a different HWID. Reset it using the bot."
    elseif code == "KEY_INCORRECT" then
        return "Key is wrong or deleted."
    elseif code == "KEY_INVALID" then
        return "Key format is invalid (empty / wrong length)."
    elseif code == "SCRIPT_ID_INCORRECT" or code == "SCRIPT_ID_INVALID" then
        return "Script configuration error. Contact the developer."
    elseif code == "INVALID_EXECUTOR" then
        return "Your executor is not supported."
    elseif code == "SECURITY_ERROR" then
        return "Cloudflare rejected the request. Try again."
    elseif code == "TIME_ERROR" then
        return "System clock is off. Fix your time and retry."
    elseif code == "UNKNOWN_ERROR" then
        return "Luarmor server error. Try again in a moment."
    else
        return "Key check failed: " .. (rawMessage or "") .. " (" .. (code or "?") .. ")"
    end
end

local function shouldPromptNewKey(code)
    return code == "KEY_EXPIRED" or code == "KEY_BANNED" or code == "KEY_INCORRECT"
end

local function loadGetKeyUI(bootFailureCode, bootFailureMessage)
    local WindUI = loadstring(game:HttpGet(WINDUI_URL))()

    local Window = WindUI:CreateWindow({
        Title = "L Hub V2  |  Key System",
        Folder = "LHub",
        Icon = "key-round",
        Size = UDim2.fromOffset(520, 360),
        HideSearchBar = true,
        OpenButton = {
            Title = "Open L Hub",
            CornerRadius = UDim.new(1, 0),
            StrokeThickness = 2,
            Enabled = true,
            Draggable = true,
        },
        Topbar = {
            Height = 42,
            ButtonsType = "Default",
        },
    })

    pcall(function()
        Window:SetToggleKey(Enum.KeyCode.L)
    end)

    local KeyTab = Window:Tab({
        Title = "Key System",
        Icon = "key-round",
        Border = true,
    })

    local UserKey = ""

    local function notify(title, content, duration)
        pcall(function()
            WindUI:Notify({
                Title = title,
                Content = content,
                Icon = "bell",
                Duration = duration or 5,
            })
        end)
    end

    KeyTab:Section({
        Title = "Enter your key to continue",
        TextSize = 18,
    })

    KeyTab:Space()

    KeyTab:Button({
        Title = "Get Key",
        Desc = "Copies the get-key link to your clipboard",
        Icon = "link",
        Callback = function()
            setclipboard(GET_KEY_LINK)
            notify("L Hub", "Get-key link copied to clipboard")
        end,
    })

    KeyTab:Space()

    KeyTab:Input({
        Title = "Key",
        Desc = "Paste your key here",
        Placeholder = "Enter key...",
        InputIcon = "key",
        Callback = function(text)
            UserKey = trim(text)
        end,
    })

    KeyTab:Space()

    KeyTab:Button({
        Title = "Verify Key",
        Desc = "Check and save your key",
        Icon = "check",
        Callback = function()
            if UserKey == "" then
                notify("L Hub", "Please paste a key first")
                return
            end

            local ok, code, message = tryLuarmor(UserKey)

            if ok then
                writefile(KEY_FILE, UserKey)
                notify("L Hub", "Key valid — loading script")
                pcall(function() Window:Destroy() end)
                return
            end

            notify("L Hub", messageForCode(code, message))

            if shouldPromptNewKey(code) then
                pcall(setclipboard, GET_KEY_LINK)
                notify("L Hub", "Get-key link copied — grab a fresh key")
            end
        end,
    })

    if bootFailureCode then
        task.spawn(function()
            task.wait(0.5)
            notify("L Hub", messageForCode(bootFailureCode, bootFailureMessage))
            if shouldPromptNewKey(bootFailureCode) then
                pcall(setclipboard, GET_KEY_LINK)
            end
        end)
    end
end

local bootFailCode, bootFailMsg

local presetKey = trim(getgenv().script_key or "")
if presetKey ~= "" then
    local ok, code, message = tryLuarmor(presetKey)
    if ok then
        writefile(KEY_FILE, presetKey)
        return
    end
    bootFailCode, bootFailMsg = code, message
end

if isfile(KEY_FILE) then
    local savedKey = trim(readfile(KEY_FILE))
    if savedKey ~= "" then
        local ok, code, message = tryLuarmor(savedKey)
        if ok then
            return
        end
        delfile(KEY_FILE)
        bootFailCode, bootFailMsg = code, message
    else
        delfile(KEY_FILE)
    end
end

loadGetKeyUI(bootFailCode, bootFailMsg)
